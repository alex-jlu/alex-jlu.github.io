---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactSection from '../components/ContactSection.astro';
import ImageSlot from '../components/ImageSlot.astro';

const aboutImage = '/about.jpg';

const experience = [
  {
    company: 'The Arc',
    subtitle: 'Product Development Studio & Consultancy',
    roles: [
      {
        title: 'Product Engineer & Manager',
        summary:
          'Developing hardware products with technical and strategic ownership for SMEs, startups, and corporate clients.',
        bullets: [
          {
            label: 'Project Delivery & Leadership',
            text: 'Leading interdisciplinary teams of 3–5 through product sprints, ensuring delivery of projects and products as well as client and supplier alignment.',
          },
          {
            label: 'Engineering Design',
            text: 'Designed, prototyped, and tested mechanical and electronic components, translating concepts into functional, manufacturable products.',
          },
          {
            label: 'Product & Engineering Ownership',
            text: 'Owning products and subsystems, from concept to launch into de-risked, production-ready engineered solutions.',
          },
          {
            label: 'Product Strategy',
            text: 'Scoping products, defining requirements, and developing product visions aligned with market opportunities and business goals.',
          },
          {
            label: 'Integrated Product Design',
            text: 'Worked with software, UX/UI, and marketing teams to deliver connected hardware products, ensuring cohesive end-to-end solutions.',
          },
        ],
      },
      {
        title: 'Project Manager (Hardware & IoT Projects)',
        bullets: [
          {
            label: 'Process Optimisation',
            text: 'Defined and standardised workflows and assets to improve efficiency across projects.',
          },
          {
            label: 'Project Coordination',
            text: 'Aligned with product managers and engineers to ensure timely, high-quality delivery of projects.',
          },
        ],
      },
    ],
  },
  {
    company: 'Bosch',
    roles: [
      {
        title: 'Design Engineer',
        bullets: [
          {
            label: 'Engineering Design',
            text: 'Developed components for the Bosch C4000 with focus on injection moulding, sheet metal, and DfM.',
          },
          {
            label: 'Process Engineering',
            text: 'Managed part release and change processes across engineering, manufacturing, and supply chain.',
          },
          {
            label: 'Product Reliability & Safety',
            text: 'Supported DFMEA and legal certification processes for C4000 and Greenstar i products.',
          },
        ],
      },
    ],
  },
];

const skills = [
  {
    title: 'Product scoping, industrial design',
    items: [
      'Concept generation and product scoping',
      'User, commercial, market, and technical research',
      'Patent landscape, FTO & IP',
      'Product visualisation: concept sketching, 3D visualisation and photorealistic rendering',
    ],
    tools: ['Blender', 'KeyShot'],
  },
  {
    title: 'Mechanical design & manufacturing',
    items: [
      'Concept to manufacture for plastics, sheet metal, structural frames, composites',
      'DFM & supplier coordination for injection moulding, RIM, vacuum casting, metal bending, cutting, welding',
      'Design-build-test cycles with rapid prototyping (FDM, SLA)',
    ],
    tools: ['SolidWorks', 'NX 11', 'Fusion 360'],
  },
  {
    title: 'Electrical design',
    items: [
      'Electrical design: block diagrams, wiring schematics and component layout, harness design through to manufacturing',
      'Git structures and integration with software teams',
      'Power electronics design and signal/electronics design for connection of electronic components',
      'Electronics prototyping: low-level PCB prototyping and embedded development using off-the-shelf modules (e.g. Pi / COM, ESP32, STM32)',
    ],
    tools: ['SolidWorks Electrical', 'KiCad', 'C++', 'Git', 'Python'],
  },
  {
    title: 'Engineering analysis',
    items: [
      'FEA: thermal, fluid, statics, dynamics',
      'Tolerance stack-ups, GD&T',
      'Engineering principles: dynamics, statics, heat transfer, thermo fluids, materials',
    ],
    tools: ['Python', 'Abaqus', 'SolidWorks (CAE)'],
  },
  {
    title: 'Systems engineering & PLM',
    items: [
      'EVT, DVT, PVT cycles',
      'V model',
      'DFMEA (7-step)',
      'Compliance: CE, EMC, product safety, environmental testing (industrial, automotive, consumer)',
    ],
    tools: ['Teamcenter', '3DX'],
  },
];
---

<BaseLayout
  title="About"
  description="About Alexander Ludwig — Design Engineer. Hardware products from idea to manufacturing."
  hideFooter={true}
>
  <section class="about-intro">
    <div class="container about-intro__grid">
      <div class="about-intro__copy">
        <h1 class="about-intro__title">About</h1>

        <p class="about-intro__text">
          I studied Design Engineering at <strong>Loughborough University</strong> and began my
          career at <strong>Bosch</strong> before moving into engineering consulting, where I worked
          with multiple companies across engineering phases in a range of industries, primarily
          consumer-facing products. More recently, I've shifted into startups, taking on end-to-end
          hardware lead roles.
        </p>

        <hr class="about-intro__rule" />

        <p class="about-intro__text">
          To me, being a design engineer means balancing product design and engineering rigour—shaping
          design direction and product vision early on, then engineering that product in detail through
          to manufacture, preserving design intent through systems engineering and ensuring components
          and interfaces are validated at every level.
        </p>
      </div>

      <figure class="about-intro__media">
        <ImageSlot
          src={aboutImage}
          alt="Alexander Ludwig"
          label="photo"
          tone="hero"
          aspect="fill"
          loading="eager"
        />
      </figure>
    </div>
  </section>

  <section class="surface-grid about-content" aria-labelledby="experience-heading">
    <div class="container">
      <header class="about-section__header">
        <h2 class="about-section__title" id="experience-heading">Experience</h2>
      </header>

      <div class="about-experience">
        {experience.map(org => (
          <article class="about-card about-org">
            <header class="about-org__header">
              <h3 class="about-org__company">{org.company}</h3>
              {org.subtitle && <p class="about-org__subtitle">{org.subtitle}</p>}
            </header>

            {org.roles.map(role => (
              <div class="about-role">
                <h4 class="about-role__title">{role.title}</h4>
                {role.summary && <p class="about-role__summary">{role.summary}</p>}
                <ul class="about-list about-role__list">
                  {role.bullets.map(item => (
                    <li class="about-list__item about-role__item">
                      <strong class="about-role__label">{item.label}</strong>
                      <span class="about-role__text">{item.text}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </article>
        ))}
      </div>

      <header class="about-section__header about-section__header--spaced">
        <h2 class="about-section__title" id="skills-heading">Skills</h2>
      </header>

      <div class="about-skills" aria-labelledby="skills-heading">
        {skills.map(group => (
          <article class="about-card about-skill">
            <h3 class="about-skill__title">{group.title}</h3>
            <ul class="about-list about-skill__list">
              {group.items.map(item => (
                <li class="about-list__item about-skill__item">{item}</li>
              ))}
            </ul>
            <div class="about-skill__tools">
              <span class="about-skill__tools-label">Tools</span>
              <ul class="about-pills" role="list">
                {group.tools.map(tool => (
                  <li><span class="about-pill">{tool}</span></li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ContactSection />
</BaseLayout>

<script>
  function syncAboutMediaHeight() {
    const copy = document.querySelector<HTMLElement>('.about-intro__copy');
    const media = document.querySelector<HTMLElement>('.about-intro__media');
    if (!copy || !media) return;

    if (window.matchMedia('(max-width: 900px)').matches) {
      media.style.minHeight = '';
      return;
    }

    media.style.minHeight = `${copy.offsetHeight}px`;
  }

  syncAboutMediaHeight();
  window.addEventListener('resize', syncAboutMediaHeight);
  document.fonts?.ready.then(syncAboutMediaHeight);
</script>

<style>
  /* ── Intro (matches home hero) ─────────────────────────────────── */
  .about-intro {
    padding-block: clamp(1.5rem, 3vw, 2.5rem) clamp(2rem, 4vw, 3rem);
  }

  .about-intro__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) var(--hero-media-w);
    align-items: stretch;
    gap: clamp(1rem, 2vw, 1.75rem);
  }

  .about-intro__copy {
    grid-column: 1;
    grid-row: 1;
    max-width: var(--hero-copy-max);
  }

  .about-intro__title {
    font-size: var(--text-cases-title);
    font-weight: var(--weight-medium);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    color: var(--color-black);
    margin-bottom: clamp(1.5rem, 3vw, 2rem);
  }

  .about-intro__text {
    font-size: var(--text-sm);
    line-height: var(--leading-loose);
    color: var(--color-text-2);
    max-width: 52ch;
    margin-bottom: var(--space-5);
  }

  .about-intro__text:first-of-type {
    font-size: var(--text-base);
    color: var(--color-text-1);
  }

  .about-intro__text strong {
    font-weight: var(--weight-semibold);
    color: var(--color-black);
  }

  .about-intro__rule {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-bottom: var(--space-5);
  }

  .about-intro__media {
    grid-column: 2;
    grid-row: 1;
    margin: 0;
    min-height: 100%;
    height: 100%;
    display: grid;
    border-radius: var(--radius-media);
    overflow: hidden;
  }

  .about-intro__media :global(.image-slot) {
    grid-area: 1 / 1;
    border-radius: 0;
  }

  /* ── Main content (grid + noise) ───────────────────────────────── */
  .about-content {
    padding-block: clamp(3rem, 6vw, 5rem) clamp(2rem, 4vw, 3rem);
  }

  .about-section__header {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .about-section__header--spaced {
    margin-top: clamp(3rem, 6vw, 5rem);
  }

  .about-section__title {
    font-size: var(--text-cases-title);
    font-weight: var(--weight-medium);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    color: var(--color-black);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Shared cards & lists ──────────────────────────────────────── */
  .about-card {
    background: rgba(215, 217, 222, 0.35);
    border: none;
    border-radius: var(--radius-box);
    padding: clamp(1.25rem, 3vw, 2rem);
    box-shadow: none;
    backdrop-filter: blur(8px) saturate(105%);
    -webkit-backdrop-filter: blur(8px) saturate(105%);
  }

  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .about-card {
      background: rgba(241, 243, 245, 0.88);
    }
  }

  .about-list {
    list-style: disc;
    padding-left: 1.25em;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .about-list__item {
    padding-left: 0.25em;
  }

  .about-list__item::marker {
    color: var(--color-black);
  }

  .about-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .about-pill {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-3);
    background: var(--color-black);
    color: var(--color-white);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }

  /* ── Experience ──────────────────────────────────────────────────── */
  .about-experience {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .about-org__header {
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid rgba(215, 217, 222, 0.65);
  }

  .about-org__company {
    font-size: var(--text-case-title);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    color: var(--color-black);
  }

  .about-org__subtitle {
    margin-top: 0.15em;
    font-size: clamp(var(--text-lg), 2vw, var(--text-xl));
    font-weight: var(--weight-normal);
    line-height: var(--leading-snug);
    color: var(--color-text-2);
  }

  .about-role + .about-role {
    margin-top: var(--space-8);
    padding-top: var(--space-8);
    border-top: 1px solid rgba(215, 217, 222, 0.65);
  }

  .about-role__title {
    display: inline-block;
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .about-role__summary {
    font-size: var(--text-sm);
    line-height: var(--leading-loose);
    color: var(--color-text-2);
    margin-bottom: var(--space-5);
  }

  .about-role__list {
    max-width: none;
  }

  .about-role__item {
    font-size: var(--text-sm);
    line-height: var(--leading-loose);
    color: var(--color-text-2);
  }

  .about-role__label {
    display: block;
    font-weight: var(--weight-semibold);
    color: var(--color-black);
    margin-bottom: 0.15em;
  }

  .about-role__text {
    display: block;
  }

  /* ── Skills ────────────────────────────────────────────────────── */
  .about-skills {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 420px), 1fr));
    gap: var(--space-6);
  }

  .about-skill {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .about-skill__title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-snug);
    color: var(--color-black);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid rgba(215, 217, 222, 0.65);
  }

  .about-skill__list {
    flex: 1;
    margin-bottom: var(--space-5);
  }

  .about-skill__item {
    font-size: var(--text-sm);
    line-height: var(--leading-loose);
    color: var(--color-text-2);
  }

  .about-skill__tools {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(215, 217, 222, 0.65);
  }

  .about-skill__tools-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-3);
  }

  @media (max-width: 900px) {
    .about-intro__grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
      gap: var(--space-5);
    }

    .about-intro__copy {
      grid-column: 1;
      grid-row: 1;
    }

    .about-intro__media {
      grid-column: 1;
      grid-row: 2;
      min-height: 280px;
      height: auto;
      aspect-ratio: 16 / 10;
    }

    .about-intro__media :global(.image-slot) {
      min-height: 280px;
    }
  }
</style>
