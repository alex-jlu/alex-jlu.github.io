---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseRow from '../components/CaseRow.astro';

const allCases = (
  await getCollection('cases', ({ data }) => data.publish)
).sort((a, b) => a.data.order - b.data.order);

const industryCases = allCases.filter(c => c.data.category === 'industry');
const academicCases = allCases.filter(c => c.data.category === 'academic-personal');

const clients = ['Bliq', 'Bosch', 'Bace', 'ABV', 'Daikin', 'Technicolor', 'SOLID'];
---

<BaseLayout
  title="Alexander Ludwig"
  description="Design Engineer with 4+ years in consumer-facing hardware products. Mechanical, electrical, industrial design and systems engineering from idea to manufacturing."
>

  <!-- ── Hero ──────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero__grid">

      <div class="hero__left">
        <h1 class="hero__heading">
          I design, engineer &amp; lead hardware products
        </h1>
        <p class="hero__sub">From Idea to Manufacturing</p>
        <p class="hero__disciplines">
          Mechanical Design, Electrical Design, Industrial Design, Systems Engineering
        </p>
        <p class="hero__bio">
          4+ years in consumer products across industries — startup-minded, balancing
          creative concept with engineering rigor and systematic execution to build
          hardware that ships.
        </p>
      </div>

      <div class="hero__right" aria-hidden="true">
        <div class="hero__image-placeholder"></div>
      </div>

    </div>

    <!-- Logo strip -->
    <div class="container">
      <ul class="logo-strip" role="list" aria-label="Clients and companies">
        {clients.map(name => (
          <li class="logo-strip__item">{name}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── Cases ─────────────────────────────────────────────────────── -->
  <section class="cases-section" aria-labelledby="cases-heading">
    <div class="container">

      <h2 class="cases-heading" id="cases-heading">Cases</h2>

      {industryCases.length > 0 && (
        <div class="cases-group">
          <p class="cases-label">From Industry</p>
          <div class="cases-list">
            {industryCases.map((entry, i) => (
              <CaseRow
                slug={entry.slug}
                title={entry.data.title}
                summary={entry.data.summary}
                tags={entry.data.tags}
                heroImage={entry.data.heroImage}
                index={i}
              />
            ))}
          </div>
        </div>
      )}

      {academicCases.length > 0 && (
        <div class="cases-group">
          <p class="cases-label">Academic &amp; Personal</p>
          <div class="cases-list">
            {academicCases.map((entry, i) => (
              <CaseRow
                slug={entry.slug}
                title={entry.data.title}
                summary={entry.data.summary}
                tags={entry.data.tags}
                heroImage={entry.data.heroImage}
                index={i}
              />
            ))}
          </div>
        </div>
      )}

    </div>
  </section>

  <!-- ── Contact ───────────────────────────────────────────────────── -->
  <section class="contact-section" aria-labelledby="contact-heading">
    <div class="container contact-grid">

      <div class="contact-left">
        <h2 class="contact-heading" id="contact-heading">Contact</h2>
        <div class="contact-image-placeholder" aria-hidden="true"></div>
      </div>

      <div class="contact-right">
        <p class="contact-message">Thanks for scrolling down to here</p>
        <p class="contact-body">
          If you are interested in finding out more about myself, my work or
          projects please feel free to reach out.
        </p>
        <ul class="contact-links" role="list">
          <li>
            <a href="mailto:alexander.josefludwig@web.de" class="contact-link">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <rect x="1" y="3" width="14" height="10" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M1.5 4L8 9.5L14.5 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              alexander.josefludwig@web.de
            </a>
          </li>
          <li>
            <a
              href="https://linkedin.com/in/alexmkrludwig"
              class="contact-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <rect x="1" y="1" width="14" height="14" rx="2" stroke="currentColor" stroke-width="1.3"/>
                <path d="M4 6.5v5M4 4v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M7.5 11.5V9c0-1.38.5-2.5 2-2.5s2 1 2 2.5v2.5M7.5 6.5v5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              @alexmkrludwig
            </a>
          </li>
        </ul>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────── */
  .hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid var(--color-border);
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--space-12);
    align-items: start;
    margin-bottom: var(--space-12);
  }

  .hero__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .hero__heading {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-text-1);
    max-width: 14ch;
  }

  .hero__sub {
    font-size: var(--text-base);
    font-weight: var(--weight-normal);
    color: var(--color-accent);
    margin-top: var(--space-1);
  }

  .hero__disciplines {
    font-size: var(--text-sm);
    color: var(--color-text-2);
    line-height: var(--leading-normal);
  }

  .hero__bio {
    font-size: var(--text-sm);
    color: var(--color-text-2);
    line-height: var(--leading-loose);
    max-width: 52ch;
    margin-top: var(--space-2);
  }

  /* Hero image placeholder */
  .hero__right {
    position: relative;
  }

  .hero__image-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--color-bg-subtle);
  }

  /* Logo strip */
  .logo-strip {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding-top: var(--space-2);
  }

  .logo-strip__item {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-3);
    text-transform: uppercase;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  /* ── Cases ────────────────────────────────────────────────────────── */
  .cases-section {
    padding-top: var(--space-16);
    padding-bottom: var(--space-20);
  }

  .cases-heading {
    font-size: clamp(var(--text-4xl), 7vw, var(--text-6xl));
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-text-1);
    margin-bottom: var(--space-6);
  }

  .cases-group {
    margin-bottom: var(--space-12);
  }

  .cases-label {
    font-size: var(--text-sm);
    font-weight: var(--weight-normal);
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .cases-list {
    border-top: 1px solid var(--color-border);
  }

  /* ── Contact ──────────────────────────────────────────────────────── */
  .contact-section {
    background: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-16);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .contact-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .contact-heading {
    font-size: var(--text-3xl);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-1);
  }

  .contact-image-placeholder {
    width: 100%;
    aspect-ratio: 1;
    background: var(--color-bg-hover);
  }

  .contact-right {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-top: var(--space-2);
  }

  .contact-message {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-1);
    line-height: var(--leading-snug);
  }

  .contact-body {
    font-size: var(--text-sm);
    color: var(--color-text-2);
    line-height: var(--leading-loose);
    max-width: 52ch;
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-5);
    margin-top: var(--space-2);
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-1);
    transition: color var(--transition-base);
  }

  .contact-link:hover {
    color: var(--color-accent);
  }

  /* ── Responsive ───────────────────────────────────────────────────── */
  @media (max-width: 800px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }

    .hero__right {
      display: none;
    }

    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-image-placeholder {
      display: none;
    }
  }
</style>
