---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseCard from '../../components/CaseCard.astro';

const allCases = (
  await getCollection('cases', ({ data }) => data.publish)
).sort((a, b) => b.data.year - a.data.year);

const allTags = [...new Set(allCases.flatMap(c => c.data.tags))].sort();
---

<BaseLayout
  title="Work"
  description="Selected case studies by Alexander Ludwig — design systems, product design, interactive prototypes, and more."
>
  <section class="work-page">
    <div class="container">

      <div class="work-header">
        <h1 class="page-title">Work</h1>
        <p class="work-header__sub">
          Case studies from my work as a design engineer.
        </p>
      </div>

      {allTags.length > 0 && (
        <div class="tag-filter" role="group" aria-label="Filter by tag">
          <button class="filter-btn filter-btn--active" data-tag="">All</button>
          {allTags.map(tag => (
            <button class="filter-btn" data-tag={tag}>{tag}</button>
          ))}
        </div>
      )}

      {allCases.length > 0 ? (
        <div class="cases-grid" id="cases-grid">
          {allCases.map(entry => (
            <div class="grid-item" data-tags={entry.data.tags.join(',')}>
              <CaseCard
                slug={entry.slug}
                title={entry.data.title}
                company={entry.data.company}
                role={entry.data.role}
                year={entry.data.year}
                tags={entry.data.tags}
                summary={entry.data.summary}
                heroImage={entry.data.heroImage}
                featured={entry.data.featured}
              />
            </div>
          ))}
        </div>
      ) : (
        <p class="empty-state">No published case studies yet — check back soon.</p>
      )}

    </div>
  </section>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const gridItems = document.querySelectorAll<HTMLElement>('.grid-item');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag ?? '';

      filterBtns.forEach(b => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');

      gridItems.forEach(item => {
        if (!tag) {
          item.hidden = false;
        } else {
          const itemTags = (item.dataset.tags ?? '').split(',');
          item.hidden = !itemTags.includes(tag);
        }
      });
    });
  });
</script>

<style>
  .work-page {
    padding-top: var(--space-20);
    padding-bottom: var(--space-24);
  }

  .work-header {
    margin-bottom: var(--space-10);
    max-width: var(--max-w-content);
  }

  .page-title {
    font-size: clamp(var(--text-4xl), 8vw, var(--text-7xl));
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-text-1);
    margin-bottom: var(--space-4);
  }

  .work-header__sub {
    font-size: var(--text-lg);
    color: var(--color-text-2);
    line-height: var(--leading-normal);
  }

  /* Tag filter */
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-10);
  }

  .filter-btn {
    padding: var(--space-2) var(--space-4);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-2);
    background: transparent;
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .filter-btn:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text-1);
  }

  .filter-btn--active {
    background: var(--color-text-1);
    border-color: var(--color-text-1);
    color: var(--color-bg);
  }

  /* Grid */
  .cases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 400px) {
    .cases-grid {
      grid-template-columns: 1fr;
    }
  }

  .empty-state {
    color: var(--color-text-2);
    font-size: var(--text-base);
    padding-block: var(--space-20);
    text-align: center;
  }
</style>
