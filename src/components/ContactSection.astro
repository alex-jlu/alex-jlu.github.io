---
---

<section class="contact" id="contact" aria-labelledby="contact-heading">
  <div class="container">
    <div class="contact__panel">
      <h2 class="contact__heading" id="contact-heading">Contact</h2>

      <div class="contact__grid">
        <div class="contact__photo" aria-hidden="true">
          <span class="contact__photo-label">photo</span>
        </div>

        <div class="contact__body">
          <p class="contact__thanks">Thanks for scrolling down to here</p>
          <p class="contact__text">
            If you are interested in finding out more about myself, my work or projects
            please feel free to reach out.
          </p>

          <ul class="contact__links" role="list">
            <li>
              <a href="mailto:your@email.com" class="contact__link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M4 6h16v12H4V6Z" stroke="currentColor" stroke-width="1.5"/>
                  <path d="m4 7 8 6 8-6" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                your@email.com
              </a>
            </li>
            <li>
              <a
                href="https://linkedin.com/in/your-handle"
                class="contact__link"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M8 11v5M8 8v.01M12 16v-5c0-1 1-2 2-2s2 1 2 2v5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                @alexanderludwig
              </a>
            </li>
            <li>
              <a href="tel:+0000000000" class="contact__link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M6 4h4l2 5-2 1c1 2 3 4 5 5l1-2 5 2v4c0 1-1 2-2 2C9 21 3 15 3 7c0-1 1-2 2-3Z" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                +00 000 000 0000
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    padding-block: var(--space-8) var(--space-10);
  }

  .contact__panel {
    background: var(--color-dark);
    color: var(--color-white);
    border-radius: var(--radius-box);
    padding: var(--space-16) clamp(1.25rem, 4vw, 2.5rem) var(--space-12);
  }

  .contact__heading {
    font-size: clamp(var(--text-4xl), 6vw, var(--text-6xl));
    font-weight: var(--weight-medium);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-12);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: minmax(160px, 280px) 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  .contact__photo {
    aspect-ratio: 1;
    box-sizing: border-box;
    border: 1px solid var(--color-border);
    background: var(--color-bg-subtle);
    border-radius: var(--radius-media);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact__photo-label {
    font-size: var(--text-sm);
    color: var(--color-text-3);
  }

  .contact__thanks {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-5);
  }

  .contact__text {
    font-size: var(--text-base);
    line-height: var(--leading-loose);
    color: rgba(255, 255, 255, 0.75);
    max-width: 48ch;
    margin-bottom: var(--space-10);
  }

  .contact__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6) var(--space-10);
  }

  .contact__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-white);
    transition: opacity var(--transition-base);
  }

  .contact__link:hover {
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }

    .contact__photo {
      max-width: 200px;
    }
  }
</style>
