---
interface Props {
  company: string;
  subtitle: string;
  description: string;
  roles: string[];
  image?: string;
  imageLabel?: string;
  href?: string;
}

const {
  company,
  subtitle,
  description,
  roles,
  image,
  imageLabel = 'img',
  href,
} = Astro.props;

const imageAlt = `${company} — ${subtitle}`;
---

<article class="home-case-card">
  {href ? (
    <a href={href} class="home-case-card__link">
      <div class="home-case-card__media">
        {image ? (
          <img
            src={image}
            alt={imageAlt}
            class="home-case-card__image"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="home-case-card__placeholder" aria-hidden="true">
            <span class="home-case-card__placeholder-label">{imageLabel}</span>
          </div>
        )}
      </div>

      <div class="home-case-card__banner">
        <p class="home-case-card__company">{company}</p>
        <p class="home-case-card__subtitle">{subtitle}</p>
      </div>
    </a>
  ) : (
    <>
      <div class="home-case-card__media">
        {image ? (
          <img
            src={image}
            alt={imageAlt}
            class="home-case-card__image"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="home-case-card__placeholder" aria-hidden="true">
            <span class="home-case-card__placeholder-label">{imageLabel}</span>
          </div>
        )}
      </div>

      <div class="home-case-card__banner">
        <p class="home-case-card__company">{company}</p>
        <p class="home-case-card__subtitle">{subtitle}</p>
      </div>
    </>
  )}

  <div class="home-case-card__body">
    <p class="home-case-card__description">{description}</p>
    <hr class="home-case-card__rule" />
    <ul class="home-case-card__roles" role="list">
      {roles.map(role => (
        <li>
          <span class="home-case-card__pill">{role}</span>
        </li>
      ))}
    </ul>
  </div>
</article>

<style>
  .home-case-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .home-case-card__link {
    display: block;
    transition: opacity var(--transition-base);
  }

  .home-case-card__link:hover {
    opacity: 0.88;
  }

  .home-case-card__media {
    aspect-ratio: 1;
    width: 100%;
    overflow: hidden;
    background: var(--color-bg-subtle);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }

  .home-case-card__image,
  .home-case-card__placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  .home-case-card__image {
    object-fit: cover;
    object-position: center center;
  }

  .home-case-card__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .home-case-card__placeholder-label {
    font-size: var(--text-sm);
    color: var(--color-text-3);
  }

  .home-case-card__banner {
    background: var(--color-black);
    color: var(--color-white);
    padding: var(--space-4) var(--space-4) var(--space-3);
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  }

  .home-case-card__company {
    font-size: clamp(1.125rem, 1.5vw, 1.375rem);
    font-weight: var(--weight-semibold);
    line-height: 1.1;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .home-case-card__subtitle {
    margin-top: 0.2em;
    font-size: clamp(0.8125rem, 1vw, 0.9375rem);
    font-weight: var(--weight-normal);
    line-height: 1.2;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    opacity: 0.92;
  }

  .home-case-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding-top: var(--space-4);
  }

  .home-case-card__description {
    font-size: var(--text-sm);
    line-height: var(--leading-loose);
    color: var(--color-text-2);
    margin-bottom: var(--space-5);
  }

  .home-case-card__rule {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-bottom: var(--space-3);
    width: 100%;
  }

  .home-case-card__roles {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: auto;
    list-style: none;
    padding: 0;
  }

  .home-case-card__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem var(--space-3);
    background: var(--color-black);
    color: var(--color-white);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    line-height: 1;
    border-radius: var(--radius-pill);
  }
</style>
