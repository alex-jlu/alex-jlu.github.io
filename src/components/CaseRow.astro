---
interface Props {
  company: string;
  subtitle: string;
  description: string;
  tags: string;
  imageLabel?: string;
  reverse?: boolean;
  href?: string;
}

const {
  company,
  subtitle,
  description,
  tags,
  imageLabel = 'img',
  reverse = false,
  href,
} = Astro.props;

const TitleTag = href ? 'a' : 'div';
---

<article class:list={['case-row', { 'case-row--reverse': reverse }]}>
  <div class="case-row__media">
    <div class="case-row__placeholder" aria-hidden="true">
      <span class="case-row__placeholder-label">{imageLabel}</span>
    </div>
  </div>

  <div class="case-row__content">
    {href ? (
      <a href={href} class="case-row__title-link">
        <h3 class="case-row__title">
          <span class="case-row__company">{company}</span>
          <span class="case-row__subtitle">{subtitle}</span>
        </h3>
      </a>
    ) : (
      <h3 class="case-row__title">
        <span class="case-row__company">{company}</span>
        <span class="case-row__subtitle">{subtitle}</span>
      </h3>
    )}

    <p class="case-row__description">{description}</p>
    <hr class="case-row__rule" />
    <p class="case-row__tags">{tags}</p>
  </div>
</article>

<style>
  .case-row {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }

  .case-row--reverse {
    grid-template-columns: 1fr 300px;
  }

  .case-row--reverse .case-row__media {
    order: 2;
  }

  .case-row--reverse .case-row__content {
    order: 1;
    text-align: right;
  }

  .case-row--reverse .case-row__description {
    margin-inline-start: auto;
  }

  .case-row--reverse .case-row__rule {
    margin-inline-start: auto;
  }

  .case-row__media {
    width: 100%;
    max-width: 300px;
  }

  .case-row--reverse .case-row__media {
    margin-inline-start: auto;
  }

  .case-row__placeholder {
    aspect-ratio: 1;
    width: 100%;
    box-sizing: border-box;
    border: 1px solid var(--color-border);
    background: var(--color-bg-subtle);
    border-radius: var(--radius-media);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .case-row__placeholder-label {
    font-size: var(--text-sm);
    color: var(--color-text-3);
  }

  .case-row__title-link {
    display: block;
    transition: opacity var(--transition-base);
  }

  .case-row__title-link:hover {
    opacity: 0.65;
  }

  .case-row__title {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1em;
    font-size: var(--text-case-title);
    font-weight: var(--weight-normal);
    line-height: var(--leading-tight);
    color: var(--color-black);
    margin-bottom: var(--space-4);
  }

  .case-row--reverse .case-row__title {
    align-items: flex-end;
  }

  .case-row__company {
    font-weight: var(--weight-semibold);
  }

  .case-row__subtitle {
    font-weight: var(--weight-normal);
  }

  .case-row__description {
    font-size: var(--text-sm);
    line-height: var(--leading-loose);
    color: var(--color-text-2);
    max-width: 46ch;
    margin-bottom: var(--space-5);
  }

  .case-row__rule {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-bottom: var(--space-3);
    width: 100%;
    max-width: 46ch;
  }

  .case-row__tags {
    font-size: var(--text-xs);
    color: var(--color-text-3);
    line-height: var(--leading-normal);
  }

  @media (max-width: 768px) {
    .case-row,
    .case-row--reverse {
      grid-template-columns: 1fr;
    }

    .case-row--reverse .case-row__media,
    .case-row--reverse .case-row__content {
      order: unset;
      text-align: left;
    }

    .case-row--reverse .case-row__description,
    .case-row--reverse .case-row__rule {
      margin-inline-start: 0;
    }

    .case-row--reverse .case-row__media {
      margin-inline-start: 0;
    }

    .case-row__media {
      max-width: 280px;
    }
  }
</style>
