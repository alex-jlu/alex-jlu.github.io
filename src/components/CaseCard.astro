---
import TagList from './TagList.astro';

interface Props {
  slug: string;
  title: string;
  company?: string;
  role: string;
  year: number;
  tags: string[];
  summary: string;
  heroImage?: string;
  featured?: boolean;
}

const { slug, title, company, role, year, tags, summary, heroImage, featured } = Astro.props;
---

<article class="case-card">
  <a href={`/work/${slug}`} class="case-card__link" aria-label={`View case study: ${title}`}>
    <div class="case-card__image-wrap">
      {heroImage ? (
        <img
          src={heroImage}
          alt={`${title} preview`}
          class="case-card__image"
          loading="lazy"
          decoding="async"
          width="800"
          height="450"
        />
      ) : (
        <div class="case-card__placeholder" aria-hidden="true">
          <span class="case-card__placeholder-label">img</span>
        </div>
      )}
      {featured && (
        <span class="case-card__badge">Featured</span>
      )}
    </div>

    <div class="case-card__body">
      <TagList tags={tags} size="sm" />
      <h3 class="case-card__title">{title}</h3>
      <p class="case-card__summary">{summary}</p>
      <footer class="case-card__meta">
        <span>{role}</span>
        {company && (
          <>
            <span class="case-card__dot" aria-hidden="true">·</span>
            <span>{company}</span>
          </>
        )}
        <span class="case-card__dot" aria-hidden="true">·</span>
        <span>{year}</span>
      </footer>
    </div>
  </a>
</article>

<style>
  .case-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition:
      transform var(--transition-base),
      box-shadow var(--transition-base),
      border-color var(--transition-base);
  }

  .case-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-border-strong);
  }

  .case-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* Image */
  .case-card__image-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    box-sizing: border-box;
    border: 1px solid var(--color-border);
    background: var(--color-bg-subtle);
    overflow: hidden;
    flex-shrink: 0;
  }

  .case-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-default);
  }

  .case-card:hover .case-card__image {
    transform: scale(1.04);
  }

  .case-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-subtle);
  }

  .case-card__placeholder-label {
    font-size: var(--text-sm);
    color: var(--color-text-3);
  }

  .case-card__badge {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    background: var(--color-accent);
    color: #fff;
    font-size: 0.6875rem;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
  }

  /* Body */
  .case-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-6) var(--space-6);
    flex: 1;
  }

  .case-card__title {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-snug);
    color: var(--color-text-1);
  }

  .case-card__summary {
    font-size: var(--text-sm);
    color: var(--color-text-2);
    line-height: var(--leading-normal);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Meta */
  .case-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    font-size: var(--text-xs);
    color: var(--color-text-3);
    margin-top: auto;
  }

  .case-card__dot {
    color: var(--color-border-strong);
  }
</style>
